rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Listing photos — only the host who owns the listing can write
    // Path: listings/{hostId}/{listingId}/{filename}
    match /listings/{hostId}/{listingId}/{filename} {
      // Anyone can read listing photos (public)
      allow read: if true;

      // Only the authenticated host matching hostId can upload/delete
      allow write: if request.auth != null
                   && request.auth.uid == hostId
                   && request.resource.size < 5 * 1024 * 1024   // max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

  }
}
