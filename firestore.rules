rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Blog posts — public read, any authenticated user can write (personal site)
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shop products — public read, any authenticated user can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Email subscribers — anyone can create (subscribe), authenticated user can read/delete
    match /emails/{emailId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

  }
}
